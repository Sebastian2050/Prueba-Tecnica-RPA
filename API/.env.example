# .env.example — Copiar como .env y ajustar valores
# Este archivo NO debe subirse al control de versiones (.gitignore)

# ── Base de datos (mismos valores que el pipeline ETL) ────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cartera_db
DB_USER=postgres
DB_PASSWORD=1234

# ── Tabla de cartera ──────────────────────────────────────────────────────────
TABLE_NAME=cartera_por_producto

# ── Servidor de la API ────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true    # cambiar a false en producción
