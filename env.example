# .env.example — Copia este archivo como .env y ajusta los valores.
# Ningún valor es obligatorio; todos tienen defaults razonables para desarrollo.

# ── Base de datos de trabajo ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cartera_db
DB_USER=postgres
DB_PASSWORD=1234

# ── Base de datos de administración (para CREATE DATABASE) ────────────────────
# Normalmente 'postgres'; solo cambiar si el servidor tiene un nombre distinto.
DB_ADMIN_NAME=postgres

# ── Pipeline ──────────────────────────────────────────────────────────────────
CSV_PATH=Distribución_de_cartera_por_producto_20260415.csv
TABLE_NAME=cartera_por_producto
BATCH_SIZE=5000

# Separador del CSV.  Dejar vacío para autodetección (más lenta en archivos grandes).
# Ejemplos: CSV_SEP=,   |   CSV_SEP=;
CSV_SEP=
